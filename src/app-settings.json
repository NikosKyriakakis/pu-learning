        },
        "fasttext-crawl": {
            "command": "wget --no-check-certificate https://dl.fbaipublicfiles.com/fasttext/vectors-english/crawl-300d-2M.vec.zip",
            "filename": "crawl-300d-2M.vec.zip"
        }
    },
    "dataset_options": {
        "deceptive-opinion.csv": "https://drive.google.com/uc?id=1QaV8r3l4EohQACCiwORr6Hqb9HQVhXV7",
